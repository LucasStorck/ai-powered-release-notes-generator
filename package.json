{
  "name": "ai-powered-release-notes",
  "version": "0.0.1",
  "private": true,
  "description": "AI-Powered Release Notes Generator — Mono-repo Workspace",
  "scripts": {
    "frontend": "npm run --prefix frontend start",
    "frontend:open": "npm run --prefix frontend start -- --open",
    "frontend:build": "npm run --prefix frontend build",
    "frontend:test": "npm run --prefix frontend test",
    "frontend:lint": "npm run --prefix frontend lint",
    "backend": "cd backend && .\\mvnw spring-boot:run",
    "backend:build": "cd backend && .\\mvnw clean package -DskipTests",
    "backend:test": "cd backend && .\\mvnw test",
    "dev": "npm-run-all --parallel --continue-on-error frontend backend",
    "dev:frontend-only": "npm run frontend:open",
    "build": "npm run frontend:build && npm run backend:build"
  },
  "workspaces": [
    "frontend"
  ],
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
